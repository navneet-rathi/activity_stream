<!DOCTYPE html>
<html>
<head>
    <style>
        body { font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; margin: 40px; color: #333; }
        .header { border-bottom: 2px solid #005596; padding-bottom: 10px; margin-bottom: 20px; }
        table { width: 100%; border-collapse: collapse; margin-top: 20px; }
        th, td { padding: 12px; border: 1px solid #ddd; text-align: left; }
        th { background-color: #f8f9fa; font-weight: bold; }
        .status-successful { color: #28a745; font-weight: bold; }
        .status-failed { color: #dc3545; font-weight: bold; }
        .summary-box { background: #e9ecef; padding: 15px; border-radius: 5px; margin-bottom: 30px; }
    </style>
</head>
<body>
    <div class="header">
        <h1>{{ report_title }}</h1>
        <p><strong>Period:</strong> {{ report_range }}</p>
        <p><strong>Generated On:</strong> {{ ansible_date_time.date }}</p>
    </div>

    <div class="summary-box">
        <strong>Total Jobs Executed:</strong> {{ jobs | length }}
    </div>

    <table>
        <thead>
            <tr>
                <th>Job ID</th>
                <th>Template Name</th>
                <th>Status</th>
                <th>Finished At</th>
                <th>Logs</th>
            </tr>
        </thead>
        <tbody>
            {% for job in jobs %}
            <tr>
                <td>{{ job.id }}</td>
                <td>{{ job.name }}</td>
                <td class="status-{{ job.status }}">{{ job.status | capitalize }}</td>
                <td>{{ job.finished }}</td>
                <td>
                    <div id="terminal-output"></div>

    <script>
        // 2. Inject the dynamic playbook output using Jinja syntax
        // The | safe filter is used to prevent escaping of special characters
        const rawData = "{{ {{ lookup('ansible.builtin.url', 'https://192.168.64.63' ~ job.related.stdout ~ '?format=html', validate_certs='false', username='admin', password='primod123', force_basic_auth='True')| to_nice_yaml(indent=4)}} | safe }}";

        function parseLogs(input) {
            const container = document.getElementById('terminal-output');
            // Split by comma to treat each as a new line
            const lines = input.split(',');
            
            lines.forEach(line => {
                const cleanLine = line.trim();
                if (!cleanLine) return;

                const p = document.createElement('div');
                
                // Dynamic styling logic
                if (cleanLine.includes('PLAY [')) p.className = 'header';
                else if (cleanLine.includes('TASK [')) p.className = 'task';
                else if (cleanLine.includes('ok:')) p.className = 'status-ok';
                else if (cleanLine.includes('changed:')) p.className = 'status-changed';
                
                p.innerText = cleanLine;
                container.appendChild(p);
            });
        }

        parseLogs(rawData);
                
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</body>
</html>
